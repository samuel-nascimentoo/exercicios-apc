#include <stdio.h>
 
int main(){
    
   int senha = 2002;
   
   while (1){
       
       int tentativa;
       scanf("%d", &tentativa);
       
       if(tentativa == senha){
           printf("Acesso Permitido\n");
           break;
       }
       else{
           printf("Senha Invalida\n");
       }
   }

    return 0;
}
